<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#18A303"/>
      <stop offset="100%" stop-color="#0f7c00"/>
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="8" stdDeviation="12" flood-opacity="0.25"/>
    </filter>
  </defs>
  <rect width="1200" height="630" fill="url(#g)"/>

  <!-- decorative circles -->
  <circle cx="1080" cy="70" r="140" fill="rgba(255,255,255,0.06)"/>
  <circle cx="1050" cy="40" r="70" fill="rgba(255,255,255,0.05)"/>

  <!-- card -->
  <rect x="80" y="120" width="680" height="320" rx="18" fill="#ffffff" filter="url(#shadow)"/>

  <!-- logo mark (generic document + arrow) -->
  <g transform="translate(110,170)">
    <rect x="0" y="0" width="110" height="110" rx="16" fill="#18A303"/>
    <polygon points="35,82 90,45 90,82" fill="#ffffff"/>
  </g>

  <!-- headline -->
  <text x="240" y="210" font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="44" font-weight="700" fill="#0b0b0b">LibreOffice for Windows</text>
  <text x="240" y="260" font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="28" font-weight="600" fill="#18A303">Free Download (64‑bit) — MSI Offline Installer</text>

  <!-- bullets -->
  <g font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="22" fill="#6b7280">
    <text x="240" y="305">• Windows 10 & 11 (64‑bit)</text>
    <text x="240" y="340">• Writer, Calc, Impress, Draw, Base, Math</text>
    <text x="240" y="375">• Opens DOCX/XLSX/PPTX • Exports PDF</text>
  </g>

  <!-- right side badge -->
  <g transform="translate(860, 430)">
    <rect x="0" y="0" width="260" height="70" rx="14" fill="rgba(255,255,255,0.2)" stroke="rgba(255,255,255,0.35)"/>
    <text x="20" y="44" font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="24" font-weight="700" fill="#ffffff">Open‑source • Free</text>
  </g>

  <!-- footer tagline -->
  <text x="80" y="500" font-family="Segoe UI, Roboto, Helvetica, Arial, sans-serif" font-size="18" fill="rgba(255,255,255,0.9)">Not affiliated with The Document Foundation — links point to official servers</text>
</svg>